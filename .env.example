# Camera mode: true = mock frames, false = real RTSP stream
USE_MOCK_CAMERA=true

# RTSP stream URL (used when USE_MOCK_CAMERA=false)
RTSP_URL=rtsp://127.0.0.1:554/stream

# Capture/encode FPS
CAMERA_FPS=15

# Server port (API + WebSocket)
PORT=3001

# RDK deployment (for scripts/deploy.sh)
# RDK_USER=root
# RDK_HOST=192.168.1.100
